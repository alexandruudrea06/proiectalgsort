                if time_taken:
                    results[f"{algo_name}_{size}"] = time_taken
                    print(f"  {algo_name}: {time_taken:.2f}s")
        
        return results
    
    def test_data_structures(self, size):
        print("\n" + "="*60)
        print(f"TESTING: Different Data Structures (Size: {size})")
        print("="*60)
        
        structures = {
            'Random': TestDataGenerator.random_integers(size),
            'Sorted': TestDataGenerator.sorted_integers(size),
            'Reverse': TestDataGenerator.reverse_sorted_integers(size),
            '98% Sorted': TestDataGenerator.almost_sorted_integers(size, 2),
            'Few Unique': TestDataGenerator.few_unique_integers(size)
        }
        
        results = {}
        for struct_name, arr in structures.items():
            print(f"\n--- {struct_name} ---")
            
            for algo_name, algo_func in self.algorithms.items():
                if algo_name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                    continue
                
                time_taken = self.test_algorithm(algo_name, algo_func, arr)
                if time_taken:
                    results[f"{algo_name}_{struct_name}"] = time_taken
                    print(f"  {algo_name}: {time_taken:.2f}s")
        
        return results
    
    def test_half_sorted(self, size):
        print("\n" + "="*60)
        print(f"TESTING: Half Sorted Arrays (Size: {size})")
        print("="*60)
        
        arr = TestDataGenerator.half_sorted_integers(size)
        results = {}
        
        for algo_name, algo_func in self.algorithms.items():
            if algo_name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                continue
            
            time_taken = self.test_algorithm(algo_name, algo_func, arr)
            if time_taken:
                results[algo_name] = time_taken
                print(f"  {algo_name}: {time_taken:.2f}s")
        
        return results
    
    def test_data_types(self, size):
        print("\n" + "="*60)
        print(f"TESTING: Different Data Types (Size: {size})")
        print("="*60)
        
        data_types = {
            'Integers': TestDataGenerator.random_integers(size, 0, 10000),
            'Floats': TestDataGenerator.random_floats(size),
            'Strings': TestDataGenerator.random_strings(size, 10)
        }
        
        results = {}
        for dtype_name, arr in data_types.items():
            print(f"\n--- {dtype_name} ---")
            
            for algo_name, algo_func in self.algorithms.items():
                if algo_name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                    continue
                
                time_taken = self.test_algorithm(algo_name, algo_func, arr)
                if time_taken:
                    results[f"{algo_name}_{dtype_name}"] = time_taken
                    print(f"  {algo_name}: {time_taken:.2f}s")
        
        return results
    
    def run_all_tests(self):
        print("\n" + "="*60)
        print("SORTING ALGORITHMS EXPERIMENTAL COMPARISON")
        print("="*60)
        print(f"Python version: {sys.version}")
        
        random.seed(42)
        
        all_results = {}
        
        all_results['many_small'] = self.test_many_small(100000, [20, 30, 50, 100])
        all_results['medium'] = self.test_medium_arrays([1000, 5000, 10000, 50000])
        all_results['large'] = self.test_large_arrays([100000, 500000, 1000000])
        all_results['structures'] = self.test_data_structures(1000000)
        all_results['half_sorted'] = self.test_half_sorted(1000000)
        all_results['data_types'] = self.test_data_types(100000)
        
        return all_results


