import time
import random
import string

class SortingAlgorithms:
    @staticmethod
    def bubble_sort(arr):
        arr = arr.copy()
        n = len(arr)
        for i in range(n):
            swapped = False
            for j in range(0, n-i-1):
                if arr[j] > arr[j+1]:
                    arr[j], arr[j+1] = arr[j+1], arr[j]
                    swapped = True
            if not swapped:
                break
        return arr
    
    @staticmethod
    def insertion_sort(arr):
        arr = arr.copy()
        for i in range(1, len(arr)):
            key = arr[i]
            j = i-1
            while j >= 0 and arr[j] > key:
                arr[j+1] = arr[j]
                j -= 1
            arr[j+1] = key
        return arr
    
    @staticmethod
    def selection_sort(arr):
        arr = arr.copy()
        n = len(arr)
        for i in range(n):
            min_idx = i
            for j in range(i+1, n):
                if arr[j] < arr[min_idx]:
                    min_idx = j
            arr[i], arr[min_idx] = arr[min_idx], arr[i]
        return arr
    
    @staticmethod
    def merge_sort(arr):
        if len(arr) <= 1:
            return arr
        mid = len(arr) // 2
        left = SortingAlgorithms.merge_sort(arr[:mid])
        right = SortingAlgorithms.merge_sort(arr[mid:])
        return SortingAlgorithms._merge(left, right)
    
    @staticmethod
    def _merge(left, right):
        result = []
        i = j = 0
        while i < len(left) and j < len(right):
            if left[i] <= right[j]:
                result.append(left[i])
                i += 1
            else:
                result.append(right[j])
                j += 1
        result.extend(left[i:])
        result.extend(right[j:])
        return result
    
    @staticmethod
    def quick_sort(arr):
        if len(arr) <= 1:
            return arr
        pivot = arr[len(arr) // 2]
        left = [x for x in arr if x < pivot]
        middle = [x for x in arr if x == pivot]
        right = [x for x in arr if x > pivot]
        return SortingAlgorithms.quick_sort(left) + middle + SortingAlgorithms.quick_sort(right)
    
    @staticmethod
    def heap_sort(arr):
        arr = arr.copy()
        n = len(arr)
        for i in range(n // 2 - 1, -1, -1):
            SortingAlgorithms._heapify(arr, n, i)
        for i in range(n-1, 0, -1):
            arr[i], arr[0] = arr[0], arr[i]
            SortingAlgorithms._heapify(arr, i, 0)
        return arr
    
    @staticmethod
    def _heapify(arr, n, i):
        largest = i
        left = 2*i + 1
        right = 2*i + 2
        if left < n and arr[left] > arr[largest]:
            largest = left
        if right < n and arr[right] > arr[largest]:
            largest = right
        if largest != i:
            arr[i], arr[largest] = arr[largest], arr[i]
            SortingAlgorithms._heapify(arr, n, largest)
    
    @staticmethod
    def timsort(arr):
        return sorted(arr)


def generate_data(size, data_type="random"):
    if data_type == "random":
        return [random.randint(0, 10000) for _ in range(size)]
    elif data_type == "sorted":
        return list(range(size))
    elif data_type == "reverse":
        return list(range(size-1, -1, -1))
    elif data_type == "almost_sorted":
        arr = list(range(size))
        for _ in range(int(size * 0.02)):
            i, j = random.sample(range(size), 2)
            arr[i], arr[j] = arr[j], arr[i]
        return arr
    elif data_type == "half_sorted":
        half = size // 2
        return list(range(half)) + [random.randint(half, size*2) for _ in range(size - half)]
    elif data_type == "few_unique":
        return [random.randint(0, 9) for _ in range(size)]
    elif data_type == "floats":
        return [random.uniform(0, 1000) for _ in range(size)]
    elif data_type == "strings":
        return [''.join(random.choice('abcdefghijklmnopqrstuvwxyz') for _ in range(10)) for _ in range(size)]


def test_algorithm(algo, arr):
    try:
        start = time.time()
        result = algo(arr)
        end = time.time()
        if len(arr) <= 1000:
            assert result == sorted(arr)
        return end - start
    except:
        return None


def run_test(name, algo, size, data_type="random"):
    arr = generate_data(size, data_type)
    time_taken = test_algorithm(algo, arr)
    if time_taken:
        print(f"  {name:15s}: {time_taken:.4f}s")
    return time_taken


def main():
    print("="*60)
    print("SORTING ALGORITHMS COMPARISON")
    print("="*60)
    
    algorithms = {
        'Bubble Sort': SortingAlgorithms.bubble_sort,
        'Insertion Sort': SortingAlgorithms.insertion_sort,
        'Selection Sort': SortingAlgorithms.selection_sort,
        'Merge Sort': SortingAlgorithms.merge_sort,
        'Quick Sort': SortingAlgorithms.quick_sort,
        'Heap Sort': SortingAlgorithms.heap_sort,
        'Timsort': SortingAlgorithms.timsort
    }
    
    # 1. Many Small Lists
    print("\n" + "-"*50)
    print("MANY SMALL LISTS (100,000 lists)")
    print("-"*50)
    for size in [20, 30, 50, 100]:
        print(f"\nSize {size}:")
        for name, algo in algorithms.items():
            if size > 50 and name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                print(f"  {name:15s}: SKIPPED")
                continue
            total = 0
            for _ in range(1000):
                arr = generate_data(size, "random")
                t = test_algorithm(algo, arr)
                if t:
                    total += t
            print(f"  {name:15s}: {total:.2f}s total")
    
    # 2. Medium Arrays
    print("\n" + "-"*50)
    print("MEDIUM ARRAYS (Random Data)")
    print("-"*50)
    for size in [1000, 5000, 10000]:
        print(f"\nSize {size}:")
        for name, algo in algorithms.items():
            if size > 5000 and name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                print(f"  {name:15s}: SKIPPED")
                continue
            run_test(name, algo, size)
    
    # 3. Large Arrays
    print("\n" + "-"*50)
    print("LARGE ARRAYS (Random Data)")
    print("-"*50)
    for size in [100000, 500000]:
        print(f"\nSize {size}:")
        for name, algo in algorithms.items():
            if name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                continue
            run_test(name, algo, size)
    
    # 4. Different Data Structures
    print("\n" + "-"*50)
    print("DIFFERENT DATA STRUCTURES (Size 100,000)")
    print("-"*50)
    structures = ['random', 'sorted', 'reverse', 'almost_sorted', 'few_unique']
    for struct in structures:
        print(f"\n{struct.upper()}:")
        for name, algo in algorithms.items():
            if name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                continue
            run_test(name, algo, 100000, struct)
    
    # 5. Half Sorted
    print("\n" + "-"*50)
    print("HALF SORTED ARRAYS (Size 100,000)")
    print("-"*50)
    for name, algo in algorithms.items():
        if name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
            continue
        run_test(name, algo, 100000, "half_sorted")
    
    # 6. Different Data Types
    print("\n" + "-"*50)
    print("DIFFERENT DATA TYPES (Size 50,000)")
    print("-"*50)
    for dtype in ['integers', 'floats', 'strings']:
        print(f"\n{dtype.upper()}:")
        for name, algo in algorithms.items():
            if name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                continue
            run_test(name, algo, 50000, dtype)
    
    print("\n" + "="*60)
    print("TESTING COMPLETE")
    print("="*60)


if __name__ == "__main__":
    random.seed(42)
    main()
