import time
import random
import string
import sys

class SortingAlgorithms:
    @staticmethod
    def bubble_sort(arr):
        arr = arr.copy()
        n = len(arr)
        for i in range(n):
            swapped = False
            for j in range(0, n-i-1):
                if arr[j] > arr[j+1]:
                    arr[j], arr[j+1] = arr[j+1], arr[j]
                    swapped = True
            if not swapped:
                break
        return arr
    
    @staticmethod
    def insertion_sort(arr):
        arr = arr.copy()
        for i in range(1, len(arr)):
            key = arr[i]
            j = i-1
            while j >= 0 and arr[j] > key:
                arr[j+1] = arr[j]
                j -= 1
            arr[j+1] = key
        return arr
    
    @staticmethod
    def selection_sort(arr):
        arr = arr.copy()
        n = len(arr)
        for i in range(n):
            min_idx = i
            for j in range(i+1, n):
                if arr[j] < arr[min_idx]:
                    min_idx = j
            arr[i], arr[min_idx] = arr[min_idx], arr[i]
        return arr
    
    @staticmethod
    def merge_sort(arr):
        arr = arr.copy()
        if len(arr) <= 1:
            return arr
        mid = len(arr) // 2
        left = SortingAlgorithms.merge_sort(arr[:mid])
        right = SortingAlgorithms.merge_sort(arr[mid:])
        return SortingAlgorithms._merge(left, right)
    
    @staticmethod
    def _merge(left, right):
        result = []
        i = j = 0
        while i < len(left) and j < len(right):
            if left[i] <= right[j]:
                result.append(left[i])
                i += 1
            else:
                result.append(right[j])
                j += 1
        result.extend(left[i:])
        result.extend(right[j:])
        return result
    
    @staticmethod
    def quick_sort(arr):
        arr = arr.copy()
        return SortingAlgorithms._quick_sort_helper(arr)
    
    @staticmethod
    def _quick_sort_helper(arr):
        if len(arr) <= 1:
            return arr
        pivot = arr[len(arr) // 2]
        left = [x for x in arr if x < pivot]
        middle = [x for x in arr if x == pivot]
        right = [x for x in arr if x > pivot]
        return SortingAlgorithms._quick_sort_helper(left) + middle + SortingAlgorithms._quick_sort_helper(right)
    
    @staticmethod
    def heap_sort(arr):
        arr = arr.copy()
        n = len(arr)
        for i in range(n // 2 - 1, -1, -1):
            SortingAlgorithms._heapify(arr, n, i)
        for i in range(n-1, 0, -1):
            arr[i], arr[0] = arr[0], arr[i]
            SortingAlgorithms._heapify(arr, i, 0)
        return arr
    
    @staticmethod
    def _heapify(arr, n, i):
        largest = i
        left = 2*i + 1
        right = 2*i + 2
        if left < n and arr[left] > arr[largest]:
            largest = left
        if right < n and arr[right] > arr[largest]:
            largest = right
        if largest != i:
            arr[i], arr[largest] = arr[largest], arr[i]
            SortingAlgorithms._heapify(arr, n, largest)
    
    @staticmethod
    def timsort(arr):
        return sorted(arr)


class TestDataGenerator:
    @staticmethod
    def random_integers(size, min_val=0, max_val=1000000):
        return [random.randint(min_val, max_val) for _ in range(size)]
    
    @staticmethod
    def sorted_integers(size):
        return list(range(size))
    
    @staticmethod
    def reverse_sorted_integers(size):
        return list(range(size-1, -1, -1))
    
    @staticmethod
    def almost_sorted_integers(size, disorder_percentage=2):
        arr = list(range(size))
        num_swaps = int(size * disorder_percentage / 100)
        for _ in range(num_swaps):
            i, j = random.sample(range(size), 2)
            arr[i], arr[j] = arr[j], arr[i]
        return arr
    
    @staticmethod
    def half_sorted_integers(size):
        half = size // 2
        sorted_part = list(range(half))
        random_part = [random.randint(half, size*2) for _ in range(size - half)]
        return sorted_part + random_part
    
    @staticmethod
    def few_unique_integers(size, unique_count=10):
        return [random.randint(0, unique_count-1) for _ in range(size)]
    
    @staticmethod
    def random_floats(size):
        return [random.uniform(0, 1000) for _ in range(size)]
    
    @staticmethod
    def random_strings(size, str_length=10):
        letters = string.ascii_lowercase
        return [''.join(random.choice(letters) for _ in range(str_length)) for _ in range(size)]
    
    @staticmethod
    def many_small_lists(num_lists, size):
        return [[random.randint(0, 1000) for _ in range(size)] for _ in range(num_lists)]


class SortingTester:
    def __init__(self):
        self.algorithms = {
            'Bubble Sort': SortingAlgorithms.bubble_sort,
            'Insertion Sort': SortingAlgorithms.insertion_sort,
            'Selection Sort': SortingAlgorithms.selection_sort,
            'Merge Sort': SortingAlgorithms.merge_sort,
            'Quick Sort': SortingAlgorithms.quick_sort,
            'Heap Sort': SortingAlgorithms.heap_sort,
            'Timsort': SortingAlgorithms.timsort
        }
        self.results = {}
    
    def test_algorithm(self, algo_name, algo_func, arr):
        try:
            start_time = time.time()
            result = algo_func(arr)
            end_time = time.time()
            
            if len(arr) <= 1000:
                assert result == sorted(arr), f"{algo_name} failed!"
            
            return end_time - start_time
        except Exception as e:
            print(f"  Error in {algo_name}: {e}")
            return None
    
    def test_many_small(self, num_lists, sizes):
        print("\n" + "="*60)
        print("TESTING: Many Small Lists")
        print("="*60)
        
        results = {}
        for size in sizes:
            print(f"\n--- Size: {size} ({num_lists} lists) ---")
            arrays = TestDataGenerator.many_small_lists(num_lists, size)
            
            for algo_name, algo_func in self.algorithms.items():
                if size > 50 and algo_name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                    print(f"  {algo_name}: SKIPPED (too slow)")
                    continue
                
                total_time = 0
                for arr in arrays[:1000]:
                    time_taken = self.test_algorithm(algo_name, algo_func, arr)
                    if time_taken:
                        total_time += time_taken
                
                results[f"{algo_name}_{size}"] = total_time
                print(f"  {algo_name}: {total_time:.1f}s")
        
        return results
    
    def test_medium_arrays(self, sizes):
        print("\n" + "="*60)
        print("TESTING: Medium Arrays (Random Data)")
        print("="*60)
        
        results = {}
        for size in sizes:
            print(f"\n--- Size: {size} ---")
            arr = TestDataGenerator.random_integers(size)
            
            for algo_name, algo_func in self.algorithms.items():
                if size > 10000 and algo_name in ['Bubble Sort', 'Insertion Sort', 'Selection Sort']:
                    print(f"  {algo_name}: SKIPPED (too slow)")
                    continue
                
                time_taken = self.test_algorithm(algo_name, algo_func, arr)
                if time_taken:
                    results[f"{algo_name}_{size}"] = time_taken
                    print(f"  {algo_name}: {time_taken:.3f}s")
        
        return results
    
    def test_large_arrays(self, sizes):
        print("\n" + "="*60)
        print("TESTING: Large Arrays (Random Data)")
        print("="*60)
        
        results = {}
        for size in sizes:
            print(f"\n--- Size: {size} ---")
            arr = TestDataGenerator.random_integers(size)
            
            for algo_name, algo_func in self.algorithms.items():
